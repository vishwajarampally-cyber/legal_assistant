# Express Server Configuration
PORT=5000

# LLM Provider Configuration
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1

# Pinecone Database Configuration
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_pinecone_index_name_here

# Optional logging and observability
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=advanced-rag
# For EU/APAC/AWS LangSmith workspaces, set the matching endpoint from LangSmith docs.
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# Vercel/serverless should use false so traces flush before the function exits.
LANGCHAIN_CALLBACKS_BACKGROUND=false

# Maximum file size (bytes) for uploads. Default is 50MB.
# Example: 52428800 or 50MB
MAX_FILE_SIZE=52428800

# Optional: directory to temporarily store uploaded files. Defaults to the OS temp directory.
# UPLOAD_DIR=C:\\path\\to\\uploads

# Optional chunk settings to keep embeddings within model limits.
# CHUNK_SIZE is characters per chunk, CHUNK_OVERLAP is overlap between chunks.
# Default is 120/20.
# CHUNK_SIZE=120
# CHUNK_OVERLAP=20

# Optional embedding batch size for Pinecone inference.
# Default is 90, because Pinecone's inference endpoint may cap inputs around 96.
# EMBEDDING_BATCH_SIZE=90
